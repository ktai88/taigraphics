---
import "../styles/global.css";
import Nav from '../components/Nav.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import Footer from '../components/Footer.astro';
import Meta from '../components/Meta.astro';
import FadeIn from '../components/FadeIn.astro';
---

<html lang="nl">
  <head>
    <Meta />
    <title>TaiGraphics - UX/UI Designer met passie voor Visual Design, Branding en Front-end Development</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
  </head>
  <body>

<Nav active="showcase" />

    <header class="mt-8 mb-6" role="banner"> 
      <div class="page-container-960 py-6">
        <h1 class="text-4xl text-[color:var(--color-text-heading)]">Visual <strong class="text-[color:var(--color-text-strong)]">showcase</strong></h1>
        <p class="mt-6 mb-2 font-semibold text-xs uppercase tracking-[0.1em] text-[color:var(--color-text-label)]"><span class="border-t-[2px] border-[color:var(--color-primary)] pt-3">Creativiteit zit hier!</span></p>
      </div>
    </header>

    <section class="section-alt py-2" role="main">
      <div class="page-container-960">
      <!-- Usecase Card is repeatable -->
      <div class="fade-in my-8">
        <div class="grid grid-cols-[100%] md:grid-cols-[30%_70%] gap-2 card-base">
          <div class="overflow-hidden md:rounded-l-lg">
            <img src="/thumb009.png" class="w-full h-full object-cover object-top object-left"/>
          </div>
          <div class="p-4 pr-10">
            <p class="text-[color:var(--color-text-subtle)] font-light text-sm my-3">Visual Design, Logo, Branding, Product Design</p>
            <p class="text-md leading-8 py-4">Talloze concepten omgezet in visueel aantrekkelijke en functionele ontwerpen. Een overzicht van verschillende visuals waar je lekker doorheen kunt scrollen!</p>
          </div>
        </div>
      </div>
      <!-- End Repeatable Usecase Card -->
    </section>

    <section role="complementary">
      <div class="page-container-960 mt-10 pb-10">
        <h2 class="fade-in text-2xl mb-4"><span class="font-bold text-[color:var(--color-primary)]">Logo Design</span> Showcase</h2>
        <div class="fade-in mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Column 1 -->
        <div class="overflow-hidden rounded-lg bg-white shadow">
          <img src="/logo000.png" alt="Risk Explorer" class="w-full h-full object-cover" />
        </div>

        <!-- Column 2 -->
        <div class="overflow-hidden rounded-lg bg-white shadow">
          <img src="/logo001.png" alt="Tosti Talk" class="w-full h-full object-cover" />
        </div>

        <!-- Column 3 -->
        <div class="overflow-hidden rounded-lg bg-white shadow">
          <img src="/logo002.png" alt="Koppie Copy" class="w-full h-full object-cover" />
        </div>

                <!-- Column 1 -->
        <div class="overflow-hidden rounded-lg bg-white shadow">
          <img src="/logo003.png" alt="Avisi" class="w-full h-full object-cover" />
        </div>

        <!-- Column 2 -->
        <div class="overflow-hidden rounded-lg bg-white shadow">
          <img src="/logo004.png" alt="Fulcro" class="w-full h-full object-cover" />
        </div>

        <!-- Column 3 -->
        <div class="overflow-hidden rounded-lg bg-white shadow">
          <img src="/logo005.png" alt="Astron Tulp" class="w-full h-full object-cover" />
        </div>
      </div>


      <h2 class="fade-in text-2xl mt-15"><span class="font-bold text-[color:var(--color-primary)]">Visual Design</span> Showcase</h2>

      <!-- Card is repeatable -->
      <div class="fade-in my-8">
        <a href="https://www.behance.net/gallery/56247319/Iconography-Avisi" target="_blank" class="group grid grid-cols-[100%] md:grid-cols-[30%_70%] gap-2 card-base card-interactive">
          <div class="overflow-hidden md:rounded-l-lg">
            <img src="/thumb005.png" class="w-full h-full object-cover object-top object-left "/>
          </div>
          <div class="p-4 pr-10">
            <p class="text-[color:var(--color-text-subtle)] font-light text-sm my-3">Visual Design / Branding / Iconography</p>
            <h3 class="text-3xl pt-1 pb-2">Iconography</h3>
            <p class="text-md leading-8 py-4">Ik kan je helpen met het opzetten van een Iconen Bibliotheek. Iconen die spreken: helder, consistent en betekenisvol, zodat elke visual direct communiceert.</p>
            <span class="text-[color:var(--color-primary)]">Behance - Icons bekijken (Extern)</span>
          </div>
        </a>
      </div>
      <!-- End Repeatable Card -->

      <div class="fade-in mx-auto grid grid-cols-1 md:grid-cols-2 my-8 gap-6">
        <!-- Column 1 -->
        <div class="overflow-hidden rounded-lg bg-white shadow">
          <img src="/artifact000.png" alt="Science Platform" class="w-full h-full object-cover" />
        </div>

        <!-- Column 2 -->
        <div class="overflow-hidden rounded-lg bg-white shadow">
          <img src="/artifact001.png" alt="Resource managfer" class="w-full h-full object-cover" />
        </div>
      </div>

      <div class="fade-in mx-auto grid grid-cols-1 md:grid-cols-1 my-8 gap-6">
        <!-- Full Column -->
        <div class="overflow-hidden rounded-lg bg-white shadow">
          <img src="/artifact000.png" alt="Science Platform" class="w-full h-full object-cover" />
        </div>
      </div>

            <!-- Card is repeatable -->
      <div class="fade-in my-8">
        <a href="https://www.linkedin.com/pulse/make-your-brand-modulair-design-system-part-1-creating-kevin-tai/" target="_blank" class="group grid grid-cols-[100%] md:grid-cols-[30%_70%] gap-2 card-base card-interactive">
          <div class="overflow-hidden md:rounded-l-lg">
            <img src="/1532594197356.jpg" class="w-full h-full object-cover object-top object-left "/>
          </div>
          <div class="p-4 pr-10">
            <p class="text-[color:var(--color-text-subtle)] font-light text-sm my-3">System / Branding / Modulair</p>
            <h3 class="text-3xl pt-1 pb-2">Brand systems</h3>
            <p class="text-md leading-8 py-4">Een brandsystem helpt ontwerpers om consistenter assets en materialen te maken, terwijl ze toch creatief en flexibel kunnen blijven zonder de identiteit te verliezen.</p>
            <span class="text-[color:var(--color-primary)]">Lees LinkedIn Pulse Artikel (Extern)</span>
          </div>
        </a>
      </div>
      <!-- End Repeatable Card -->

      <div class="fade-in mx-auto grid grid-cols-1 md:grid-cols-2 my-8 gap-6">
        <!-- Column 1 -->
        <div class="overflow-hidden rounded-lg bg-white shadow">
          <img src="/4f072c15364313.5629000ce7ce0.webp" alt="Verzekeruzelf" class="w-full h-full object-cover" />
        </div>

        <!-- Column 2 -->
        <div class="overflow-hidden rounded-lg bg-white shadow">
          <img src="/koppie.png" alt="Branding Koppie-Copy" class="w-full h-full object-cover" />
        </div>
      </div>

      <div class="fade-in mx-auto grid grid-cols-1 md:grid-cols-1 my-8 gap-6">
        <!-- Full Column 1 -->
       <!-- Recommendation Card is repeatable -->
        <div class="grid grid-cols-[100%] gap-2 bg-white rounded-xl shadow my-8 overflow-hidden">
        <div class="p-12">
          <h2 class="font-mono text-xs">Recommendation</h2>
          <p class="text-md font-serif leading-8 py-2">&quot;Kevin heeft voor mij <a href="https://www.behance.net/gallery/6855921/KoppieCopy" class="link-inline" target="_blank">www.koppie-copy.nl</a> ontworpen en gebouwd. En ik prijs me nog iedere dag gelukkig dat ik hem voor die klus heb gevraagd. Hij toonde zich heel betrokken bij het project en heeft veel meer gedaan dan alleen het design en de realisatie. Ik vertelde hem over de bedrijfsidentiteit van Koppie Copy, wat ik wilde uitstralen. Hij speelde daar perfect op in en verzon de visuele branding.&quot;</p>
          <p class="text-xs text-[color:var(--color-primary)] leading-8 py-2"><strong>Alexandar Djuric (April, 2013)</strong><br/><span class="text-[color:var(--color-text-subtle)]">Videostrateeg en partner bij Fideo & Redtail Studios</span></p>
        </div>
      </div>
      <!-- End Recommendation Usecase Card -->
      </div>


      <div class="fade-in mx-auto grid grid-cols-1 md:grid-cols-1 my-8 gap-6">

        <!-- Full Column 1 -->
        <div class="overflow-hidden rounded-lg bg-white shadow">
          <img src="/knb00.png" alt="UX UI Koninklijk Notariaal Beroepsorganisatie - Design System and User Interfaces" class="w-full h-full object-cover" />
        </div>
      </div>

      <div class="fade-in mx-auto grid grid-cols-1 md:grid-cols-1 my-8 gap-6">
        <!-- Full Column 1 -->
        <div class="overflow-hidden rounded-lg bg-white shadow">
          <img src="/techradar.png" alt="Avisi Technology Radar" class="w-full h-full object-cover" />
        </div>
      </div>

      <div class="fade-in mx-auto grid grid-cols-1 md:grid-cols-1 my-8 gap-6">
        <!-- Full Column 1 -->
        <div class="overflow-hidden rounded-lg bg-white shadow">
          <img src="/techradar2.png" alt="Avisi Technology Radar - Fasering" class="w-full h-full object-cover" />
        </div>
      </div>
      <div class="fade-in mx-auto grid grid-cols-1 md:grid-cols-1 my-8 gap-6">
      <!-- Full Column 1 -->
       <!-- Recommendation Card is repeatable -->
        <div class="grid grid-cols-[100%] gap-2 bg-white rounded-xl shadow my-8 overflow-hidden">
        <div class="p-12">
          <h2 class="font-mono text-xs">Recommendation</h2>
          <p class="text-md font-serif leading-8 py-2">&quot;Kevin is altijd bereid om mee te denken bij het ontwerpen van onder andere logo's en t-shirts, en weet elke keer weer iets moois neer te zetten. Hij denkt graag mee over mijn idee&euml;n en is flexibel in de uitvoering ervan. Hij is betrouwbaar en werkt secuur. Kevin is mijn vast aanspreekpunt voor zowel nieuwe ontwerpen als aanpassingen op bestaande ontwerpen.&quot;</p>
          <p class="text-xs text-[color:var(--color-primary)] leading-8 py-2"><strong>Tommy van Extel  (Januari, 2023)</strong><br/><span class="text-[color:var(--color-text-subtle)]">Van Extel IT BV</span></p>
        </div>
      </div>
      <!-- End Recommendation Usecase Card -->
      </div>     
      </div>
    </section>
      <Footer />
    <ScrollToTop />
    <FadeIn />
  </body>
</html>