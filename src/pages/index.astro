---
import HeroTyping from '../components/HeroTyping.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from "astro:content";

const caseEntries = (await getCollection("cases", ({ data }) => data.draft !== true))
  .sort((a, b) => b.data.slug.localeCompare(a.data.slug));
const uiCaseSlug = "2025-09-10-componenten-consistentie";
const uiCaseEntry = caseEntries.find((entry) => entry.data.slug === uiCaseSlug);
const uxCaseEntries = caseEntries.filter((entry) => entry.data.slug !== uiCaseSlug);
---

<BaseLayout includeFadeIn={true} title="TaiGraphics - UX/UI Designer, Visual Design, Branding & Front-end">
    <header class="hero-section mt-12 mb-10"> 
      <div class="page-container-992 py-12">
        <div class="flex items-center justify-between gap-4 md:gap-6">
          <div class="flex-1">
            <h1 class="text-[14px] md:text-2xl/10 text-[color:var(--color-text-heading)]">Hoi! Ik ben <strong class="text-[color:var(--color-text-strong)]">Kevin Tai</strong>, designer in digitale oplossingen.</h1>
            <HeroTyping />
            <p class="text-[8px] md:text-xs mt-10 mb-2 font-semibold text-xs uppercase tracking-[0.15em] text-[color:var(--color-text-label)]"><span class="border-top-gradient-3 pt-6">UX/UI, Strategy, Branding &amp; Visual Design</span></p>
          </div>
          <div class="ml-auto shrink-0 hidden md:block">
            <img
              src="/avatar-kevin-new.png"
              alt="Avatar van Kevin Tai"
              class="h-28 w-28 md:h-40 md:w-40 rounded-full object-cover object-top shadow-[0_8px_24px_rgba(0,0,0,0.18)]"
            />
          </div>
        </div>
      </div>
    </header>

    <section id="ux" class="section-alt">
      <div class="page-container-992">
      <h2 class="text-2xl my-4"><span class="font-bold text-[color:var(--color-primary)]">User Experience</span> Cases</h2>

      {uxCaseEntries.map((entry) => (
        <div>
          <a href={`/cases/${entry.data.slug}/`} class="group card-grid card-stack card-base card-interactive">
            <div class="card-image-wrap overflow-hidden md:rounded-l-lg">
              <img src={entry.data.heroImage} alt={entry.data.heroImageAlt} class="w-full h-full object-cover object-top object-left"/>
              <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn">Bekijk case</span></span>
            </div>
            <div class="card-copy">
              <p class="card-kicker">{entry.data.kicker}</p>
              <h3 class="card-title">{entry.data.title}</h3>
              <p class="card-description">{entry.data.summary}</p>
            </div>
          </a>
        </div>
      ))}

    </section>

    <section id="ui">
      <div class="page-container-992 py-10">
      <h2 class="fade-in text-2xl my-4"><span class="font-bold text-[color:var(--color-primary)]">User Interface</span> Cases</h2>

      {uiCaseEntry && (
        <div class="fade-in">
          <a href={`/cases/${uiCaseEntry.data.slug}/`} class="group card-grid card-stack card-base card-interactive">
            <div class="card-image-wrap overflow-hidden md:rounded-l-lg">
              <img src={uiCaseEntry.data.heroImage} alt={uiCaseEntry.data.heroImageAlt} class="w-full h-full object-cover object-top object-left"/>
              <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn">Bekijk case</span></span>
            </div>
            <div class="card-copy">
              <p class="card-kicker">{uiCaseEntry.data.kicker}</p>
              <h3 class="card-title">{uiCaseEntry.data.title}</h3>
              <p class="card-description">{uiCaseEntry.data.summary}</p>
            </div>
          </a>
        </div>
      )}

      <!-- Card is repeatable -->
      <div class="fade-in">
        <a target="_blank" rel="noopener noreferrer" href="https://www.linkedin.com/pulse/make-your-brand-modulair-design-system-part-2-using-kevin-tai/" class="group card-grid card-stack card-base card-interactive">
          <div class="card-image-wrap overflow-hidden md:rounded-l-lg">
            <img src="/thumb004.png" alt="Atomic Design" class="w-full h-full object-cover object-top object-left"/>
            <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn">Open LinkedIn Pulse</span></span>
          </div>
          <div class="card-copy">
            <p class="card-kicker">User Interface / Design System / Branding</p>
            <h3 class="card-title">Implementatie van Atomic Design voor Avisi</h3>
            <p class="card-description">Hoe losse onderdelen samen een krachtig geheel vormen. Dit is terug te lezen in mijn LinkedIn Pulse artikel dat ik in 2018 heb geschreven.</p>
          </div>
        </a>
      </div>
      <!-- End Repeatable Card -->

    </section>

    <section id="visuals" class="section-alt">
      <div class="page-container-992">
      <h2 class="fade-in text-2xl my-4"><span class="font-bold text-[color:var(--color-primary)]">Showcase</span> Designs</h2>

      <!-- Card is repeatable -->
      <div class="fade-in">
        <a href="/showcase" class="group card-grid card-stack card-base card-interactive">
          <div class="card-image-wrap overflow-hidden md:rounded-l-lg">
            <img src="/thumb005.png" alt="Showcase" class="w-full h-full object-cover object-top object-left"/>
            <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn">Showcase openen</span></span>
          </div>
          <div class="card-copy">
            <p class="card-kicker">Visual Design / Branding / Web / Various</p>
            <h3 class="card-title">Showcase</h3>
            <p class="card-description">Talloze concepten omgezet in visueel aantrekkelijke en functionele ontwerpen. Een overzicht van verschillende visuals waar je lekker doorheen kunt scrollen!</p>
          </div>
        </a>
      </div>
      <!-- End Repeatable Card -->

    </section>

</BaseLayout>