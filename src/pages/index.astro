---
import HeroTyping from '../components/HeroTyping.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout includeFadeIn={true} title="TaiGraphics - UX/UI Designer, Visual Design, Branding & Front-end">
    <header class="hero-section mt-12 mb-10" role="banner"> 
      <div class="page-container-960 py-12">
        <div class="flex items-center justify-between gap-4 md:gap-6">
          <div class="fade-in flex-1">
            <h1 class="text-[14px] md:text-2xl/10 text-[color:var(--color-text-heading)]">Hoi! Ik ben <strong class="text-[color:var(--color-text-strong)]">Kevin Tai</strong>, designer in digitale oplossingen.</h1>
            <HeroTyping />
            <p class="text-[8px] md:text-xs mt-10 mb-2 font-semibold text-xs uppercase tracking-[0.15em] text-[color:var(--color-text-label)]"><span class="border-top-gradient-3 pt-6">UX/UI, Strategy, Branding &amp; Visual Design</span></p>
          </div>
          <div class="fade-in ml-auto shrink-0 hidden md:block">
            <img
              src="/avatar-kevin-new.png"
              alt="Avatar van Kevin Tai"
              class="h-28 w-28 md:h-40 md:w-40 rounded-full object-cover object-top shadow-[0_8px_24px_rgba(0,0,0,0.18)]"
            />
          </div>
        </div>
      </div>
    </header>

    <section id="ux" class="section-alt section-pad">
      <div class="page-container-960">
      <h2 class="fade-in text-2xl my-4"><span class="font-bold text-[color:var(--color-primary)]">User Experience</span> Cases</h2>

      <!-- Card is repeatable -->
      <div class="fade-in">
        <a href="/cases/2025-09-23-helderheid-in-het-universum/" class="group card-grid card-stack card-base card-interactive">
          <div class="card-image-wrap overflow-hidden md:rounded-l-lg">
            <img src="/thumb000.png" alt="Helderheid in het universum" class="w-full h-full object-cover object-top object-left"/>
            <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn">Bekijk case</span></span>
          </div>
          <div class="card-copy">
            <p class="card-kicker">UX / High Level Journey Mapping / User Research</p>
            <h3 class="card-title">Helderheid in het universum</h3>
            <p class="card-description">Een UX-visie waarin complexe astronomische processen op een begrijpelijke en intu&#239;tieve manier worden vertaald naar mensgerichte ervaringen.</p>
          </div>
        </a>
      </div>
      <!-- End Repeatable Card -->

      <!-- Card is repeatable -->
      <div class="fade-in">
        <a href="/cases/2025-09-20-idee-tot-een-voorstel/" class="group card-grid card-stack card-base card-interactive">
          <div class="card-image-wrap overflow-hidden md:rounded-l-lg">
            <img src="/thumb001.png" alt="Van idee tot een ingediend waarneem-voorstel" class="w-full h-full object-cover object-top object-left"/>
            <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn">Bekijk case</span></span>
          </div>
          <div class="card-copy">
            <p class="card-kicker">User Experience / Product Design / Interface</p>
            <h3 class="card-title">Van idee tot een ingediend waarneem-voorstel</h3>
            <p class="card-description">Astronomen ondersteunen bij een effici&#235;nt, inzichtelijk en foutloos aanvraagproces, en dit proces continu iteratief verbeteren in co-creatie met stakeholders.</p>
          </div>
        </a>
      </div>
      <!-- End Repeatable Card -->

    </section>

    <section id="ui" class="section-pad">
      <div class="page-container-960">
      <h2 class="fade-in text-2xl my-4"><span class="font-bold text-[color:var(--color-primary)]">User Interface</span> Cases</h2>

      <!-- Card is repeatable -->
      <div class="fade-in">
        <a href="/cases/2025-09-10-componenten-consistentie/" class="group card-grid card-stack card-base card-interactive">
          <div class="card-image-wrap overflow-hidden md:rounded-l-lg">
            <img src="/thumb003.png" alt="Astron Design System" class="w-full h-full object-cover object-top object-left"/>
            <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn">Bekijk case</span></span>
          </div>
          <div class="card-copy">
            <p class="card-kicker">User Interface / Design System / Front-end</p>
            <h3 class="card-title">Van componenten naar coherentie en consistentie</h3>
            <p class="card-description">Een gebruiksvriendelijke interface voor het beheren van complexe systemen. Een pragmatische library, opgezet als one-team UX-er en actief meegebouwd aan de front-end.</p>
          </div>
        </a>
      </div>
      <!-- End Repeatable Card -->

      <!-- Card is repeatable -->
      <div class="fade-in">
        <a target="_blank" rel="noopener noreferrer" href="https://www.linkedin.com/pulse/make-your-brand-modulair-design-system-part-2-using-kevin-tai/" class="group card-grid card-stack card-base card-interactive">
          <div class="card-image-wrap overflow-hidden md:rounded-l-lg">
            <img src="/thumb004.png" alt="Atomic Design" class="w-full h-full object-cover object-top object-left"/>
            <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn">Open LinkedIn Pulse</span></span>
          </div>
          <div class="card-copy">
            <p class="card-kicker">User Interface / Design System / Branding</p>
            <h3 class="card-title">Implementatie van Atomic Design voor Avisi</h3>
            <p class="card-description">Hoe losse onderdelen samen een krachtig geheel vormen. Dit is terug te lezen in mijn LinkedIn Pulse artikel dat ik in 2018 heb geschreven.</p>
          </div>
        </a>
      </div>
      <!-- End Repeatable Card -->

    </section>

    <section id="visuals" class="section-alt section-pad">
      <div class="page-container-960">
      <h2 class="fade-in text-2xl my-4"><span class="font-bold text-[color:var(--color-primary)]">Showcase</span> Designs</h2>

      <!-- Card is repeatable -->
      <div class="fade-in">
        <a href="/showcase" class="group card-grid card-stack card-base card-interactive">
          <div class="card-image-wrap overflow-hidden md:rounded-l-lg">
            <img src="/thumb005.png" alt="Showcase" class="w-full h-full object-cover object-top object-left"/>
            <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn">Showcase openen</span></span>
          </div>
          <div class="card-copy">
            <p class="card-kicker">Visual Design / Branding / Web / Various</p>
            <h3 class="card-title">Showcase</h3>
            <p class="card-description">Talloze concepten omgezet in visueel aantrekkelijke en functionele ontwerpen. Een overzicht van verschillende visuals waar je lekker doorheen kunt scrollen!</p>
          </div>
        </a>
      </div>
      <!-- End Repeatable Card -->

    </section>

</BaseLayout>