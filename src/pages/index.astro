---
import "../styles/global.css";
import ScrollToTop from '../components/ScrollToTop.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Meta from '../components/Meta.astro';
import HeroTyping from '../components/HeroTyping.astro';
import FadeIn from '../components/FadeIn.astro';
---

<html lang="nl">
  <head>
    <Meta />
    <title>TaiGraphics - UX/UI Designer met passie voor Visual Design, Branding en Front-end Development</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
  </head>
  <body>
    <Nav />
    <header class="hero-section mt-12 mb-10" role="banner"> 
      <div class="page-container-960 py-12">
        <h1 class="text-[14px] md:text-2xl/10 text-[color:var(--color-text-heading)]">Hoi! Ik ben <strong class="text-[color:var(--color-text-strong)]">Kevin Tai</strong>, designer in digitale oplossingen.</h1>
        <HeroTyping />
        <p class="text-[8px] md:text-xs mt-12 mb-2 font-semibold text-xs uppercase tracking-[0.15em] text-[color:var(--color-text-label)]"><span class="border-top-gradient-3 pt-6">UX/UI, Strategy, Branding &amp; Visual Design</span></p>
      </div>
    </header>

    <section id="ux" class="section-alt py-5" role="main">
      <div class="page-container-960">
      <h2 class="fade-in text-2xl my-4"><span class="font-bold text-[color:var(--color-primary)]">User Experience</span> Cases</h2>

      <!-- Card is repeatable -->
      <div class="fade-in">
        <a href="/cases/2025-09-23-helderheid-in-het-universum/" class="group grid grid-cols-[100%] md:grid-cols-[25%_75%] gap-2 my-8 card-base card-interactive">
          <div class="card-image-wrap overflow-hidden md:rounded-l-lg">
            <img src="/thumb000.png" alt="Helderheid in het universum" class="w-full h-full object-cover object-top object-left"/>
            <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn">Bekijk case</span></span>
          </div>
          <div class="p-4 pr-10">
            <p class="text-[color:var(--color-text-subtle)] font-light text-sm my-3">UX / High Level Journey Mapping / User Research</p>
            <h3 class="text-3xl pt-1 pb-2">Helderheid in het universum</h3>
            <p class="text-md leading-8 py-4">Een UX-visie waarin complexe astronomische processen op een begrijpelijke en intu&#239;tieve manier worden vertaald naar mensgerichte ervaringen.</p>
          </div>
        </a>
      </div>
      <!-- End Repeatable Card -->

      <!-- Card is repeatable -->
      <div class="fade-in">
        <a href="/cases/2025-09-20-idee-tot-een-voorstel/" class="group grid grid-cols-[100%] md:grid-cols-[25%_75%] gap-2 my-8 card-base card-interactive">
          <div class="card-image-wrap overflow-hidden md:rounded-l-lg">
            <img src="/thumb001.png" alt="Van idee tot een ingediend waarneem-voorstel" class="w-full h-full object-cover object-top object-left"/>
            <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn">Bekijk case</span></span>
          </div>
          <div class="p-4 pr-10">
            <p class="text-[color:var(--color-text-subtle)] font-light text-sm my-3">User Experience / Product Design / Interface</p>
            <h3 class="text-3xl pt-1 pb-2">Van idee tot een ingediend waarneem-voorstel</h3>
            <p class="text-md leading-8 py-4">Astronomen ondersteunen bij een effici&#235;nt, inzichtelijk en foutloos aanvraagproces, en dit proces continu iteratief verbeteren in co-creatie met stakeholders.</p>
          </div>
        </a>
      </div>
      <!-- End Repeatable Card -->

    </section>

    <section id="ui" class="py-5" role="complementary">
      <div class="page-container-960">
      <h2 class="fade-in text-2xl my-4"><span class="font-bold text-[color:var(--color-primary)]">User Interface</span> Cases</h2>

      <!-- Card is repeatable -->
      <div class="fade-in">
        <a href="/cases/2025-09-10-componenten-consistentie/" class="group grid grid-cols-[100%] md:grid-cols-[25%_75%] gap-2 my-8 card-base card-interactive">
          <div class="card-image-wrap overflow-hidden md:rounded-l-lg">
            <img src="/thumb003.png" alt="Astron Design System" class="w-full h-full object-cover object-top object-left"/>
            <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn">Bekijk case</span></span>
          </div>
          <div class="p-4 pr-10">
            <p class="text-[color:var(--color-text-subtle)] font-light text-sm my-3">User Interface / Design System / Front-end</p>
            <h3 class="text-3xl pt-1 pb-2">Van componenten naar coherentie en consistentie</h3>
            <p class="text-md leading-8 py-4">Een gebruiksvriendelijke interface voor het beheren van complexe systemen. Een pragmatische library, opgezet als one-team UX-er en actief meegebouwd aan de front-end.</p>
          </div>
        </a>
      </div>
      <!-- End Repeatable Card -->

      <!-- Card is repeatable -->
      <div class="fade-in">
        <a target="_blank" rel="noopener noreferrer" href="https://www.linkedin.com/pulse/make-your-brand-modulair-design-system-part-2-using-kevin-tai/" class="group grid grid-cols-[100%] md:grid-cols-[25%_75%] gap-2 my-8 card-base card-interactive">
          <div class="card-image-wrap overflow-hidden md:rounded-l-lg">
            <img src="/thumb004.png" alt="Atomic Design" class="w-full h-full object-cover object-top object-left"/>
            <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn">Open LinkedIn Pulse</span></span>
          </div>
          <div class="p-4 pr-10">
            <p class="text-[color:var(--color-text-subtle)] font-light text-sm my-3">User Interface / Design System / Branding</p>
            <h3 class="text-3xl pt-1 pb-2">Implementatie van Atomic Design voor Avisi</h3>
            <p class="text-md leading-8 py-4">Hoe losse onderdelen samen een krachtig geheel vormen. Dit is terug te lezen in mijn LinkedIn Pulse artikel dat ik in 2018 heb geschreven.</p>
          </div>
        </a>
      </div>
      <!-- End Repeatable Card -->

    </section>

    <section id="visuals" class="section-alt py-5" role="complementary">
      <div class="page-container-960">
      <h2 class="fade-in text-2xl my-4"><span class="font-bold text-[color:var(--color-primary)]">Showcase</span> Designs</h2>

      <!-- Card is repeatable -->
      <div class="fade-in">
        <a href="/showcase" class="group grid grid-cols-[100%] md:grid-cols-[25%_75%] gap-2 my-8 card-base card-interactive">
          <div class="card-image-wrap overflow-hidden md:rounded-l-lg">
            <img src="/thumb005.png" alt="Showcase" class="w-full h-full object-cover object-top object-left"/>
            <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn">Showcase openen</span></span>
          </div>
          <div class="p-4 pr-10">
            <p class="text-[color:var(--color-text-subtle)] font-light text-sm my-3">Visual Design / Branding / Web / Various</p>
            <h3 class="text-3xl pt-1 pb-2">Showcase</h3>
            <p class="text-md leading-8 py-4">Talloze concepten omgezet in visueel aantrekkelijke en functionele ontwerpen. Een overzicht van verschillende visuals waar je lekker doorheen kunt scrollen!</p>
          </div>
        </a>
      </div>
      <!-- End Repeatable Card -->

    </section>

    <Footer />

    <ScrollToTop />
    <FadeIn />
  </body>
</html>