---
import "../styles/global.css";
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import Meta from '../components/Meta.astro';
---

<html lang="nl">
  <head>
    <Meta />
    <title>TaiGraphics - UX/UI Designer met passie voor Visual Design, Branding en Front-end Development</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
  </head>
  <body class="font-['Inter'] bg-[#F5F5F5]">

<Nav active="contact" />

    <header class="mt-12 mb-10" role="banner"> 
      <div class="max-w-[960px] mx-auto px-4 py-6">
        <h1 class="text-4xl text-[#333]">Say <strong class="text-[#000]">hi!</strong></h1>
        <p class="mt-6 mb-2 font-semibold text-xs uppercase tracking-[0.1em] text-[#222]"><span class="border-t-[2px] border-[#0000FF] pt-3">Plan een gesprek!</span></p>
      </div>
    </header>

    <section id="ux" class="bg-[#CEDBEF] py-5" role="main">
      <div class="max-w-[960px] mx-auto p-4">
      <!-- Calendly inline widget begin -->
      <div class="calendly-inline-widget" data-url="https://calendly.com/taigraphics-info/30min?hide_event_type_details=1&hide_gdpr_banner=1&primary_color=0000ff" style="min-width:320px;height:700px;"></div>
      <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
      <!-- Calendly inline widget end -->
      </div>
    </section>

    <Footer />
    <ScrollToTop />

  </body>
</html>