---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout active="contact" title="Contact - Say hi | TaiGraphics">

    <header class="mt-12 mb-10" role="banner"> 
      <div class="page-container-992 py-6">
        <h1 class="text-4xl text-[color:var(--color-text-heading)]">Say <strong class="text-[color:var(--color-text-strong)]">hi!</strong></h1>
        <p class="mt-6 mb-2 font-semibold text-xs uppercase tracking-[0.1em] text-[color:var(--color-text-label)]"><span class="border-t-[2px] border-[color:var(--color-primary)] pt-3">Plan een gesprek!</span></p>
      </div>
    </header>

    <section id="ux" class="section-alt">
      <div class="page-container-992">
      <!-- Calendly inline widget begin -->
      <div class="calendly-inline-widget" data-url="https://calendly.com/taigraphics-info/30min?hide_event_type_details=1&hide_gdpr_banner=1&primary_color=0000ff" style="min-width:320px;height:700px;"></div>
      <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
      <!-- Calendly inline widget end -->
      </div>
    </section>

</BaseLayout>