---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from "astro:content";

const blogEntries = (await getCollection("blog", ({ data }) => data.draft !== true))
  .sort((a, b) => b.data.slug.localeCompare(a.data.slug));
const oldestOne = blogEntries.length > 0 ? blogEntries[blogEntries.length - 1] : undefined;
const nextTwoOldest = blogEntries.slice(Math.max(blogEntries.length - 3, 0), Math.max(blogEntries.length - 1, 0));
const newestRest = blogEntries.slice(0, Math.max(blogEntries.length - 3, 0));

const formatDateToDDMMYYYY = (value: string) => {
  const monthMap: Record<string, string> = {
    januari: "01",
    februari: "02",
    maart: "03",
    april: "04",
    mei: "05",
    juni: "06",
    juli: "07",
    augustus: "08",
    september: "09",
    oktober: "10",
    november: "11",
    december: "12",
  };

  const normalized = value.trim().toLowerCase();
  const slashMatch = normalized.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (slashMatch) {
    const [, dd, mm, yyyy] = slashMatch;
    return `${dd.padStart(2, "0")}/${mm.padStart(2, "0")}/${yyyy}`;
  }

  const textMatch = normalized.match(/^(\d{1,2})\s+([a-z]+)\s+(\d{4})$/);
  if (textMatch) {
    const [, dd, monthName, yyyy] = textMatch;
    const mm = monthMap[monthName];
    if (mm) return `${dd.padStart(2, "0")}/${mm}/${yyyy}`;
  }

  return value;
};
---

<BaseLayout active="blog" includeFadeIn={true} title="On my mind - UX/UI blog | TaiGraphics">

    <header class="mt-8 mb-6" role="banner"> 
      <div class="page-container-992 py-6">
        <h1 class="text-4xl text-[color:var(--color-text-heading)]">On my <strong class="text-[color:var(--color-text-strong)]">mind</strong></h1>
        <p class="mt-6 mb-2 font-semibold text-xs uppercase tracking-[0.1em] text-[color:var(--color-text-label)]"><span class="border-t-[2px] border-[color:var(--color-primary)] pt-3">digital designer blog</span></p>
      </div>
    </header>

    <section id="ux" class="section-alt section-pad">
      <div class="page-container-992">

      <div class="fade-in grid grid-cols-1 gap-6 content-block">
        {newestRest.map((entry) => (
          <a href={`/blog/${entry.data.slug}/`} class="group flex flex-col card-base card-interactive overflow-hidden">
            <div class="card-image-wrap overflow-hidden">
              <img src={entry.data.heroImage} class="w-full h-auto " alt={entry.data.heroImageAlt} />
              <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn text-xs">Lees meer</span></span>
            </div>
            <div class="blog-overview-card-copy flex flex-col flex-1">
              <p class="card-kicker blog-meta-line">
                <span class={`blog-tag blog-tag--${entry.data.categoryVariant}`}>{entry.data.category}</span>
                <span class="text-[color:var(--color-text-subtle)]">·</span>
                <img src="/heroicons/clock.svg" class="inline mr-1 w-5 h-5 align-middle" alt="Leestijd" />
                {entry.data.readingTime} - {entry.data.date}
              </p>
              <h3 class="text-3xl pt-1 pb-2">{entry.data.title}</h3>
              <p class="card-description leading-6 flex-1">{entry.data.summary}</p>
            </div>
          </a>
        ))}
      </div>

      <div class="fade-in grid grid-cols-1 md:grid-cols-2 gap-6 content-block">
        {nextTwoOldest.map((entry) => (
          <a href={`/blog/${entry.data.slug}/`} class="group flex flex-col card-base card-interactive overflow-hidden">
            <div class="card-image-wrap overflow-hidden">
              <img src={entry.data.heroImage} class="w-full h-auto " alt={entry.data.heroImageAlt} />
              <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn text-xs">Lees meer</span></span>
            </div>
            <div class="blog-overview-card-copy flex flex-col flex-1">
              <p class="card-kicker blog-meta-line">
                <span class={`blog-tag blog-tag--${entry.data.categoryVariant}`}>{entry.data.category}</span>
                <span class="text-[color:var(--color-text-subtle)]">·</span>
                <img src="/heroicons/clock.svg" class="inline mr-1 w-5 h-5 align-middle" alt="Leestijd" />
                {entry.data.readingTime} - {entry.data.date}
              </p>
              <h3 class="text-3xl pt-1 pb-2">{entry.data.title}</h3>
              <p class="card-description leading-6 flex-1">{entry.data.summary}</p>
            </div>
          </a>
        ))}
      </div>

      <div class="fade-in grid grid-cols-1 md:grid-cols-3 gap-6 content-block">
        {oldestOne && (
          <a href={`/blog/${oldestOne.data.slug}/`} class="group flex flex-col card-base card-interactive overflow-hidden">
            <div class="card-image-wrap overflow-hidden">
              <img src={oldestOne.data.heroImage} class="w-full h-auto " alt={oldestOne.data.heroImageAlt} />
              <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn text-xs">Lees meer</span></span>
            </div>
            <div class="blog-overview-card-copy flex flex-col flex-1">
              <p class="text-[color:var(--color-text-subtle)] text-xs mt-2 mb-2">
                <span class={`blog-tag blog-tag--${oldestOne.data.categoryVariant}`}>{oldestOne.data.category}</span>
                <span class="text-[color:var(--color-text-subtle)]">·</span>
                {oldestOne.data.readingTime} - {formatDateToDDMMYYYY(oldestOne.data.date)}
              </p>
              <h3 class="text-lg pt-1 pb-2 line-clamp-2">{oldestOne.data.title}</h3>
              <p class="text-xs leading-6 text-[color:var(--color-text-subtle)] flex-1 line-clamp-3 mt-2 mb-2">{oldestOne.data.summary}</p>
            </div>
          </a>
        )}
        <a href="https://www.linkedin.com/pulse/make-your-brand-modulair-design-system-part-2-using-kevin-tai/?trackingId=UVTJTIEzTL2OD%2FsyPnyXqw%3D%3D" target="_blank" rel="noopener noreferrer" class="group flex flex-col card-base card-interactive overflow-hidden">
          <div class="card-image-wrap overflow-hidden">
            <img src="/featured-2018-08-08.png" class="w-full h-auto " alt="Featured Blog - Atomic Design" />
            <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn text-xs">Open LinkedIn Pulse</span></span>
          </div>
          <div class="blog-overview-card-copy flex flex-col flex-1">
            <p class="text-[color:var(--color-text-subtle)] text-xs mt-2 mb-2"><span class="blog-tag blog-tag--design-system">Design System</span> <span class="text-[color:var(--color-text-subtle)]">·</span> 4 min - 08/08/2018</p>
            <h3 class="text-lg pt-1 pb-2 line-clamp-2">Implementatie: Atomic Design voor Avisi (Deel 2)</h3>
            <p class="text-xs leading-6 text-[color:var(--color-text-subtle)] flex-1 line-clamp-3 mt-2 mb-2">Hoe losse onderdelen samen een krachtig geheel vormen. Dit is terug te lezen in mijn LinkedIn Pulse artikel dat ik in 2018 heb geschreven.</p>
          </div>
        </a>
        <a href="https://www.linkedin.com/pulse/make-your-brand-modulair-design-system-part-1-creating-kevin-tai/" target="_blank" rel="noopener noreferrer" class="group flex flex-col card-base card-interactive overflow-hidden">
          <div class="card-image-wrap overflow-hidden">
            <img src="/featured-2018-07-26.png" class="w-full h-auto " alt="Featured Blog - Brand System" />
            <span class="card-image-overlay" aria-hidden="true"><span class="card-image-overlay__btn text-xs">Open LinkedIn Pulse</span></span>
          </div>
          <div class="blog-overview-card-copy flex flex-col flex-1">
            <p class="text-[color:var(--color-text-subtle)] text-xs mt-2 mb-2"><span class="blog-tag blog-tag--design-system">Design System</span> <span class="text-[color:var(--color-text-subtle)]">·</span> 4 min - 26/06/2018</p>
            <h3 class="text-lg pt-1 pb-2 line-clamp-2">Implementatie: Brand System voor Avisi (Deel 1)</h3>
            <p class="text-xs leading-6 text-[color:var(--color-text-subtle)] flex-1 line-clamp-3 mt-2 mb-2">Hoe losse onderdelen samen een krachtig geheel vormen. Dit is terug te lezen in mijn LinkedIn Pulse artikel dat ik in 2018 heb geschreven.</p>
          </div>
        </a>
      </div>

      </div>
    </section>

</BaseLayout>