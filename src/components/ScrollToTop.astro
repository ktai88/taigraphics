---
// ScrollToTop.astro
---
<button
  id="scroll-top-btn"
  type="button"
  aria-label="Terug naar boven"
  class="scroll-top-button fixed w-10 h-10 bottom-6 right-33 border p-2 rounded-full shadow-lg transition-opacity duration-300 opacity-0 pointer-events-none"
>
  <span>&#8593;</span>
</button>

<script client:load>
  const btn = document.getElementById('scroll-top-btn');

  // Show/hide button after scrolling 100px
  window.addEventListener('scroll', () => {
    if (window.scrollY > 100) {
      btn.classList.remove('opacity-0', 'pointer-events-none');
      btn.classList.add('opacity-100');
    } else {
      btn.classList.add('opacity-0', 'pointer-events-none');
      btn.classList.remove('opacity-100');
    }
  });

  // Scroll to top on click
  btn.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
<script>
  const rootStyles = getComputedStyle(document.documentElement);
  const widgetColor = rootStyles.getPropertyValue('--color-primary').trim() || 'blue';
  const widgetHoverColor = rootStyles.getPropertyValue('--color-secondary').trim() || 'purple';
  const fluisterScript = document.createElement('script');
  fluisterScript.src = 'https://fluister.dev/widget.js';
  fluisterScript.dataset.project = 'fac1deb62c3e50bbae40e632f87120c372b60d0f3bfd5d3a';
  fluisterScript.dataset.style = 'minimal';
  fluisterScript.dataset.borderRadius = '50px';
  fluisterScript.dataset.icon = 'none';
  fluisterScript.dataset.color = widgetColor;
  fluisterScript.dataset.hoverColor = widgetHoverColor;
  document.body.appendChild(fluisterScript);
</script>