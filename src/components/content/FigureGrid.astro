---
interface Props {
  columns?: 1 | 2 | 3;
  className?: string;
}

const {
  columns = 2,
  className = "",
} = Astro.props as Props;

const colClass =
  columns === 1
    ? "grid-cols-1"
    : columns === 3
      ? "grid-cols-1 md:grid-cols-3"
      : "grid-cols-1 md:grid-cols-2";
---

<div class={`page-container-996 py-4 grid ${colClass} gap-4 ${className}`.trim()}>
  <slot />
</div>
