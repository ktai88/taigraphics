---
interface Props {
  title?: string;
  quote: string;
  author: string;
  subtitle?: string;
  quoteHtml?: string;
}

const {
  title = "Recommendation",
  quote,
  author,
  subtitle = "",
  quoteHtml = "",
} = Astro.props as Props;
---

<div class="grid grid-cols-[100%] gap-2 card-base card-stack">
  <div class="py-4 px-7 md:py-5 md:px-10">
    <h2 class="text-2xl mb-2">{title}</h2>
    <div class="flex items-stretch gap-4 mb-4 py-2">
      <span class="quote-card__line" aria-hidden="true"></span>
      {quoteHtml ? (
        <p class="quote-card__text text-md font-serif leading-8 whitespace-pre-line" set:html={quoteHtml} />
      ) : (
        <p class="quote-card__text text-md font-serif leading-8 whitespace-pre-line">{quote}</p>
      )}
    </div>
    <p class="text-xs text-[color:var(--color-primary)] leading-7">
      <strong>{author}</strong>
      <br />
      <span class="inline-flex items-center gap-2 mt-1">
        {subtitle && <span class="text-[color:var(--color-text-subtle)]">{subtitle}</span>}
        <span class="inline-flex items-center rounded-full bg-green-100 text-green-700 text-[10px] font-semibold px-2 py-0.5">✓ Verified on LinkedIn</span>
      </span>
    </p>
  </div>
</div>
