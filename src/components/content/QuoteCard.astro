---
interface Props {
  title?: string;
  quote: string;
  author: string;
  subtitle?: string;
  quoteHtml?: string;
}

const {
  title = "Recommendation",
  quote,
  author,
  subtitle = "",
  quoteHtml = "",
} = Astro.props as Props;
---

<div class="grid grid-cols-[100%] gap-2 card-base card-stack">
  <div class="p-6 md:p-8">
    <h2 class="text-2xl mb-2">{title}</h2>
    {quoteHtml ? (
      <p class="text-md font-serif leading-8 whitespace-pre-line mb-4" set:html={quoteHtml} />
    ) : (
      <p class="text-md font-serif leading-8 whitespace-pre-line mb-4">{quote}</p>
    )}
    <p class="text-xs text-[color:var(--color-primary)] leading-7">
      <strong>{author}</strong>
      <br />
      <span class="inline-flex items-center gap-2 mt-1">
        {subtitle && <span class="text-[color:var(--color-text-subtle)]">{subtitle}</span>}
        <span class="inline-flex items-center rounded-full bg-green-100 text-green-700 text-[10px] font-semibold px-2 py-0.5">✓ Verified on LinkedIn</span>
      </span>
    </p>
  </div>
</div>
