---
interface Props {
  href?: string;
  label?: string;
  wrapperClass?: string;
}

const {
  href = "/blog",
  label = "Terug naar overzicht",
  wrapperClass = "leading-8 content-block",
} = Astro.props as Props;
---

<p class={wrapperClass}>
  <a href={href} class="mb-2 py-2 px-6 inline-block btn-primary">{label}</a>
</p>
