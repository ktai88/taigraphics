---
interface Props {
  sectionClass?: string;
  containerClass?: string;
}

const {
  sectionClass = "",
  containerClass = "",
} = Astro.props as Props;
---

<section class={`content-section ${sectionClass}`.trim()}>
  <div class={`page-container-992 ${containerClass}`.trim()}>
    <slot />
  </div>
</section>
