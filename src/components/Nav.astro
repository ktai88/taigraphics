---
// Nav.astro
import ShowcaseContent from "./ShowcaseContent.astro";

interface Props {
  active?: 'showcase' | 'blog' | 'contact';
}

const { active } = Astro.props as Props;
---

<nav id="main-nav" class="sticky top-3 z-50 bg-white shadow-md mx-auto pl-4 pr-9 min-h-[60px] max-w-[95%] sm:max-w-[800] lg:max-w-[1000px] rounded-full flex items-center md:justify-between" aria-label="Hoofd navigatie">
    <!-- Logo -->
    <a href="/" aria-label="TaiGraphics">
    <p class="md:block text-md">
        <img class="hidden sm:block md:w-40" src="/logo.svg" alt="Logo"/>
    </p>
    </a>
    <!-- Navigation -->
    <ul class="flex ml-3 space-x-3 md:space-x-8 text-black text-xs md:text-base">
    <li class="mt-3">
      <a href="/#ux" data-nav-section="ux" class="text-nowrap nav-link">UX</a>
    </li>
    <li class="mt-3">
      <a href="/#ui" data-nav-section="ui" class="text-nowrap nav-link">UI</a>
    </li>
    <li class="mt-3">
      <a
        href="/showcase"
        data-open-showcase-modal
        aria-controls="showcase-modal"
        aria-current={active === "showcase" ? "page" : undefined}
        class={`text-nowrap nav-link ${active === "showcase" ? "text-[color:var(--color-accent-dark)] font-semibold" : ""}`}
      >
        Showcase
      </a>
    </li>
    <li class="mt-3">
      <a
        href="/blog"
        aria-current={active === "blog" ? "page" : undefined}
        class={`text-nowrap nav-link ${active === "blog" ? "text-[color:var(--color-accent-dark)] font-semibold" : ""}`}
      >
        On my mind
      </a>
    </li>
    <li>
      <a
        href="/contact"
        aria-current={active === "contact" ? "page" : undefined}
        class={`text-nowrap block mt-1 md:mt-1 btn-primary text-xs md:text-sm ${
          active === "contact" ? "ring-2 ring-offset-2 ring-[color:var(--color-primary)] font-semibold" : ""
        }`}
      >
        Say hi!
      </a>
    </li>
    </ul>
</nav>

<div id="showcase-modal" class="showcase-modal" aria-hidden="true">
  <div class="showcase-modal__panel" role="dialog" aria-modal="true" aria-labelledby="showcase-modal-title">
    <div class="showcase-modal__header">
      <h2 id="showcase-modal-title" class="showcase-modal__title">Showcase</h2>
      <button type="button" class="showcase-modal__close btn-primary" data-close-showcase-modal aria-label="Sluit showcase modal">
        Sluiten
      </button>
    </div>
    <div class="showcase-modal__content">
      <ShowcaseContent inModal={true} />
    </div>
  </div>
</div>

<script>
  const nav = document.getElementById('main-nav');
  const showcaseModal = document.getElementById('showcase-modal');
  const showcaseClose = showcaseModal?.querySelector('[data-close-showcase-modal]');
  let lastFocusedElement = null;
  const focusableSelector = [
    'a[href]',
    'button:not([disabled])',
    'textarea:not([disabled])',
    'input:not([disabled])',
    'select:not([disabled])',
    '[tabindex]:not([tabindex="-1"])',
  ].join(',');

  const getFocusableElements = () => {
    if (!showcaseModal) return [];
    return Array.from(showcaseModal.querySelectorAll(focusableSelector)).filter((element) => {
      if (!(element instanceof HTMLElement)) return false;
      return !element.hasAttribute('disabled') && element.tabIndex !== -1;
    });
  };

  const openShowcaseModal = () => {
    if (!showcaseModal) return;
    lastFocusedElement = document.activeElement;
    showcaseModal.classList.add('is-open');
    showcaseModal.setAttribute('aria-hidden', 'false');
    document.body.classList.add('modal-open');
    const [firstFocusable] = getFocusableElements();
    if (firstFocusable instanceof HTMLElement) {
      firstFocusable.focus();
    }
  };

  const closeShowcaseModal = () => {
    if (!showcaseModal) return;
    showcaseModal.classList.remove('is-open');
    showcaseModal.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('modal-open');
    if (lastFocusedElement instanceof HTMLElement) {
      lastFocusedElement.focus();
    }
  };

  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const trigger = target.closest('[data-open-showcase-modal]');
    if (trigger) {
      event.preventDefault();
      openShowcaseModal();
      return;
    }

    if (target.closest('[data-close-showcase-modal]')) {
      closeShowcaseModal();
      return;
    }

    if (showcaseModal && target === showcaseModal) {
      closeShowcaseModal();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Tab' && showcaseModal?.classList.contains('is-open')) {
      const focusableElements = getFocusableElements();
      if (focusableElements.length === 0) return;
      const first = focusableElements[0];
      const last = focusableElements[focusableElements.length - 1];
      const active = document.activeElement;

      if (event.shiftKey && active === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && active === last) {
        event.preventDefault();
        first.focus();
      }
    }

    if (event.key === 'Escape') {
      closeShowcaseModal();
    }
  });

  showcaseClose?.addEventListener('click', closeShowcaseModal);

  if (nav) {
    const isHomePage = () => {
      const p = window.location.pathname.replace(/\/$/, '') || '/';
      return p === '/' || p === '/index.html';
    };

    const sectionIds = ['ux', 'ui'];
    const sectionLinks = {};
    for (const id of sectionIds) {
      const link = nav.querySelector(`a[data-nav-section="${id}"]`);
      if (link) sectionLinks[id] = link;
    }

    const getSections = () =>
      sectionIds
        .map((id) => document.getElementById(id))
        .filter(Boolean);

    const getScrollOffset = () => {
      const firstSection = getSections()[0];
      if (firstSection) {
        const style = window.getComputedStyle(firstSection);
        const scrollMarginTop = Number.parseFloat(style.scrollMarginTop || '0');
        if (Number.isFinite(scrollMarginTop) && scrollMarginTop > 0) {
          return Math.round(scrollMarginTop);
        }
      }
      return Math.round(nav.getBoundingClientRect().height + 16);
    };

    const setSectionCurrent = (activeId) => {
      for (const id of sectionIds) {
        const link = sectionLinks[id];
        if (!link) continue;
        if (id === activeId) {
          link.classList.add('nav-link--current-section');
          link.setAttribute('aria-current', 'page');
        } else {
          link.classList.remove('nav-link--current-section');
          link.removeAttribute('aria-current');
        }
      }
    };

    const updateSectionNav = () => {
      const sections = getSections();
      if (!isHomePage() || sections.length === 0) {
        setSectionCurrent(null);
        return;
      }

      const triggerY = window.scrollY + getScrollOffset() + 1;
      let activeId = null;
      for (const section of sections) {
        const sectionTop = window.scrollY + section.getBoundingClientRect().top;
        if (triggerY >= sectionTop) {
          activeId = section.id;
        }
      }
      setSectionCurrent(activeId);
    };

    let ticking = false;
    const onScroll = () => {
      if (window.scrollY > 30) {
        nav.classList.add('nav-shrink');
      } else {
        nav.classList.remove('nav-shrink');
      }
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        updateSectionNav();
        ticking = false;
      });
    };

    const syncAfterHash = () => {
      updateSectionNav();
      requestAnimationFrame(updateSectionNav);
      setTimeout(updateSectionNav, 260);
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', updateSectionNav);
    window.addEventListener('hashchange', syncAfterHash);
    window.addEventListener('load', syncAfterHash);

    for (const id of sectionIds) {
      const link = sectionLinks[id];
      if (!link) continue;
      link.addEventListener('click', () => {
        if (!isHomePage()) return;
        setSectionCurrent(id);
        syncAfterHash();
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', syncAfterHash);
    } else {
      syncAfterHash();
    }
  }
</script>