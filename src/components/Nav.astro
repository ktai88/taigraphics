---
// Nav.astro
interface Props {
  active?: 'showcase' | 'blog' | 'contact';
}

const { active } = Astro.props as Props;
---

<nav id="main-nav" class="sticky top-3 z-50 bg-white opacity-95 shadow-md mx-auto pl-4 pr-9 min-h-[60px] max-w-[95%] sm:max-w-[800] lg:max-w-[1000px] rounded-full flex items-center md:justify-between transition-transform duration-300 ease-out" aria-label="Hoofd navigatie">
    <!-- Logo -->
    <a href="/" aria-label="TaiGraphics">
    <p class="md:block text-md">
        <img class="hidden sm:block md:w-40" src="/logo.svg" alt="Logo"/>
    </p>
    </a>
    <!-- Navigation -->
    <ul class="flex ml-3 space-x-3 md:space-x-8 text-black text-xs md:text-base">
    <li class="mt-3">
      <a href="/#ux" data-nav-section="ux" class="text-nowrap nav-link">UX</a>
    </li>
    <li class="mt-3">
      <a href="/#ui" data-nav-section="ui" class="text-nowrap nav-link">UI</a>
    </li>
    <li class="mt-3">
      <a
        href="/showcase"
        aria-current={active === "showcase" ? "page" : undefined}
        class={`text-nowrap nav-link ${active === "showcase" ? "text-[color:var(--color-primary)] font-semibold" : ""}`}
      >
        Showcase
      </a>
    </li>
    <li class="mt-3">
      <a
        href="/blog"
        aria-current={active === "blog" ? "page" : undefined}
        class={`text-nowrap nav-link ${active === "blog" ? "text-[color:var(--color-primary)] font-semibold" : ""}`}
      >
        On my mind
      </a>
    </li>
    <li>
      <a
        href="/contact"
        aria-current={active === "contact" ? "page" : undefined}
        class={`text-nowrap block mt-1 md:mt-1 btn-primary text-xs md:text-sm ${
          active === "contact" ? "ring-2 ring-offset-2 ring-[color:var(--color-primary)] font-semibold" : ""
        }`}
      >
        Say hi!
      </a>
    </li>
    </ul>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  if (nav) {
    const isHomePage = () => {
      const p = window.location.pathname.replace(/\/$/, '') || '/';
      return p === '/' || p === '/index.html';
    };

    const sectionIds = ['ux', 'ui'];

    const getSections = () =>
      sectionIds.map((id) => document.getElementById(id)).filter(Boolean);

    const sectionLinks = {};
    for (const id of sectionIds) {
      const link = nav.querySelector(`a[data-nav-section="${id}"]`);
      if (link) sectionLinks[id] = link;
    }

    const getScrollOffset = () => {
      const firstSection = getSections()[0];
      if (firstSection) {
        const style = window.getComputedStyle(firstSection);
        const scrollMarginTop = Number.parseFloat(style.scrollMarginTop || '0');
        if (Number.isFinite(scrollMarginTop) && scrollMarginTop > 0) {
          return Math.round(scrollMarginTop);
        }
      }
      return Math.round(nav.getBoundingClientRect().height + 16);
    };

    const clearSectionCurrent = () => {
      for (const id of sectionIds) {
        const link = sectionLinks[id];
        if (!link) continue;
        link.classList.remove('nav-link--current-section');
        link.removeAttribute('aria-current');
      }
    };

    const updateSectionNav = () => {
      const sections = getSections();
      if (!isHomePage() || sections.length === 0) {
        clearSectionCurrent();
        return;
      }
      const offset = getScrollOffset();
      let activeId = null;
      for (let i = sections.length - 1; i >= 0; i--) {
        const el = sections[i];
        if (el.getBoundingClientRect().top <= offset) {
          activeId = el.id;
          break;
        }
      }
      for (const id of sectionIds) {
        const link = sectionLinks[id];
        if (!link) continue;
        if (id === activeId) {
          link.classList.add('nav-link--current-section');
          link.setAttribute('aria-current', 'page');
        } else {
          link.classList.remove('nav-link--current-section');
          link.removeAttribute('aria-current');
        }
      }
    };

    let ticking = false;
    const onScroll = () => {
      if (window.scrollY > 30) {
        nav.classList.add('nav-shrink');
      } else {
        nav.classList.remove('nav-shrink');
      }
      if (!ticking) {
        requestAnimationFrame(() => {
          updateSectionNav();
          ticking = false;
        });
        ticking = true;
      }
    };

    /** Re-query sections each time — Nav script can run before #ux/#ui exist in the DOM. */
    let sectionObserver = null;
    const bindSectionObserver = () => {
      sectionObserver?.disconnect();
      const sections = getSections();
      if (!isHomePage() || sections.length === 0) return;
      const top = getScrollOffset();
      sectionObserver = new IntersectionObserver(
        () => {
          updateSectionNav();
        },
        {
          root: null,
          rootMargin: `-${top}px 0px -45% 0px`,
          threshold: [0, 0.1, 0.25, 0.5, 0.75, 1],
        },
      );
      for (const el of sections) {
        sectionObserver.observe(el);
      }
    };

    const onResize = () => {
      updateSectionNav();
      bindSectionObserver();
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onResize);
    window.addEventListener('hashchange', updateSectionNav);
    window.addEventListener('load', () => {
      updateSectionNav();
      bindSectionObserver();
    });

    const initSectionNav = () => {
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          updateSectionNav();
          bindSectionObserver();
        });
      });
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSectionNav);
    } else {
      initSectionNav();
    }
  }
</script>